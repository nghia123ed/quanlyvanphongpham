<!DOCTYPE html>
<html>
<head>
    <title>Bán hàng</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="sidebar">
        <h2>{{ ten_nv }}</h2><p>{{ quyen }}</p><hr>
        <a href="/pos" class="active">Bán hàng</a>
        <a href="/kho-hang">Kho hàng</a>
        <a href="/nhan-vien">Nhân viên</a>
        <a href="/lich-su">Lịch sử</a>
        <a href="/thong-ke">Thống kê</a>
        <a href="/logout" style="color:#ff4d4d">Đăng xuất</a>
    </div>
    <div class="content" style="display:flex; gap:20px">
        <div style="flex:2">
            <h2>DANH SÁCH SẢN PHẨM</h2>
            <table>
                <tr><th>Tên SP</th><th>Giá</th><th>Kho</th><th>SL</th><th>Thao tác</th></tr>
                {% for s in san_pham %}
                <tr>
                    <td>{{s[1]}}</td>
                    <td>{{s[2]}}đ</td>
                    <td>{{s[3]}}</td>
                    <td><input type="number" id="q-{{s[0]}}" value="1" min="1" style="width:50px"></td>
                    <td><button onclick="add('{{s[1]}}',{{s[2]}},{{s[0]}})" style="background:#28a745; color:white">Thêm</button></td>
                </tr>
                {% endfor %}
            </table>
        </div>
        <div style="flex:1; background:white; padding:20px; border-radius:10px; box-shadow:0 0 10px #ccc">
            <h3>GIỎ HÀNG</h3><div id="cart" style="min-height:200px"></div><hr>
            <h3 id="total" style="color:red; text-align:right">Tổng: 0đ</h3>
            <div id="invoiceInfo" style="display:none;margin:12px 0;padding:10px;border-radius:8px;background:#eef2ff;color:#0b63d6">
                Hóa đơn: <strong id="invId"></strong>
                <div style="font-size:13px;color:#374151;margin-top:6px">Thời gian: <span id="invTime"></span></div>
            </div>
            <button id="payBtn" onclick="pay()" style="width:100%; padding:15px; background:#28a745; color:white; font-weight:bold; border:none; cursor:pointer">THANH TOÁN</button>

            <!-- Invoice modal -->
            <div id="invoiceModal" style="display:none;position:fixed;inset:0;align-items:center;justify-content:center;background:rgba(0,0,0,0.45)">
                <div style="background:#fff;padding:18px;border-radius:8px;max-width:700px;width:96%;box-shadow:0 8px 24px rgba(2,6,23,0.4)">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                        <strong style="font-size:18px">Hóa đơn</strong>
                        <button onclick="closeInvoiceModal()" style="background:none;border:none;font-size:18px;cursor:pointer">✕</button>
                    </div>
                    <div id="invHeader" style="margin-bottom:12px;color:#374151"></div>
                    <table id="invTable" style="width:100%;border-collapse:collapse;margin-bottom:12px">
                        <thead><tr style="background:#f3f4f6"><th style="text-align:left;padding:8px">Sản phẩm</th><th style="padding:8px">Số lượng</th><th style="padding:8px">Đơn giá</th><th style="padding:8px">Thành tiền</th></tr></thead>
                        <tbody id="invBody"></tbody>
                    </table>
                    <div style="text-align:right;margin-bottom:12px"><strong id="invTotal" style="color:#ef4444"></strong></div>
                    <div style="display:flex;gap:8px;justify-content:flex-end">
                        <button onclick="closeInvoiceModal()" class="btn" style="background:#e5e7eb">Đóng</button>
                        <button onclick="printInvoice()" class="btn" style="background:#0b63d6;color:#fff">In hóa đơn</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        let cart = [];
        function add(n, p, id) {
            let q = parseInt(document.getElementById('q-' + id).value);
            let item = cart.find(x => x.name === n);
            if (item) item.quantity += q; else cart.push({ name: n, price: p, quantity: q });
            render();
        }
        function render() {
            let h = '', t = 0;
            cart.forEach((i, idx) => { h += `<p>${i.name} x${i.quantity} = ${i.price * i.quantity}đ <button onclick="cart.splice(${idx},1);render()">X</button></p>`; t += i.price * i.quantity; });
            document.getElementById('cart').innerHTML = h; document.getElementById('total').innerText = 'Tổng: ' + t + 'đ';
        }
        function pay() {
            if (cart.length == 0) return alert('Giỏ hàng trống');
        var payBtn = document.getElementById('payBtn');
        payBtn.disabled = true;
        fetch('/api/thanh-toan', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ cart: cart }) })
            .then(function(res){ return res.json().catch(function(){ return { status: 'error', message: 'Invalid response' }; }); })
            .then(function(data){
                payBtn.disabled = false;
                if(data && data.status === 'success'){
                    // Show invoice info returned by server
                    document.getElementById('invId').innerText = data.invoice || '';
                    document.getElementById('invTime').innerText = data.created || '';
                    document.getElementById('invoiceInfo').style.display = 'block';
                    // clear cart
                    cart = [];
                    render();
                    alert('Thanh toán thành công! Hóa đơn: ' + (data.invoice || ''));
                } else {
                    alert('Thanh toán thất bại: ' + (data && data.message ? data.message : 'Lỗi máy chủ'));
                }
            }).catch(function(err){
                payBtn.disabled = false;
                alert('Lỗi khi thanh toán. Vui lòng thử lại.');
            });
        }
    </script>
</body>
</html>