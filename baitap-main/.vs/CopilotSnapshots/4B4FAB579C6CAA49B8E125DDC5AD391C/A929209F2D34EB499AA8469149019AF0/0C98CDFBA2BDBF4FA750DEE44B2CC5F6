<!DOCTYPE html>
<html>
<head>
    <title>Nhân viên</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="sidebar">
        <h2>{{ ten_nv }}</h2><p>{{ quyen }}</p><hr>
        <a href="/pos">Bán hàng</a>
        <a href="/kho-hang">Kho hàng</a>
        <a href="/nhan-vien" class="active">Nhân viên</a>
        <a href="/lich-su">Lịch sử</a>
        <a href="/thong-ke">Thống kê</a>
        <a href="/logout" style="color:#ff4d4d">Đăng xuất</a>
    </div>
    <div class="content">
        <h2>QUẢN LÝ NHÂN VIÊN</h2>
        {% if quyen == 'Admin' %}
        <div style="background:#e3f2fd; padding:20px; border-radius:10px; margin-bottom:20px">
            <form method="POST">
                <input type="hidden" name="user_edit" id="ue">
                <input name="u" id="iu" placeholder="Tài khoản" required>
                <input name="p" id="ip" placeholder="Mật khẩu" required>
                <input name="t" id="it" placeholder="Họ tên" required>
                <select name="q" id="iq"><option value="NhanVien">Nhân Viên</option><option value="Admin">Admin</option></select>
                <button type="submit" style="background:#28a745; color:white; padding:8px 20px">LƯU TÀI KHOẢN</button>
            </form>
        </div>
        {% endif %}
        <table>
            <tr style="background:#333; color:white"><th>Tài khoản</th>{% if quyen == 'Admin' %}<th>Mật khẩu</th>{% endif %}<th>Họ tên</th><th>Quyền</th>{% if quyen == 'Admin' %}<th>Thao tác</th>{% endif %}</tr>
            {% for n in nhan_vien %}
            <tr>
                <td>{{n[0]}}</td>
                {% if quyen == 'Admin' %}
                <td>{{n[1]}}</td>{% endif %}
                <td>{{n[2]}}</td>
                <td>{{n[3]}}</td>
                {% if quyen == 'Admin' %}
                <td>
                    <button onclick="eNV('{{n[0]}}','{{n[1]}}','{{n[2]}}','{{n[3]}}')" style="background:#ffc107">Sửa</button>
                    {% if n[0] != 'admin' %}
                    <a href="/xoa-nv/{{n[0]}}" onclick="return confirm('Xóa?')"><button style="background:red; color:white">Xóa</button></a>
                    {% endif %}
                </td>
                {% endif %}
            </tr>
            {% endfor %}
        </table>
    </div>
    <script>
        function eNV(u, p, t, q) { document.getElementById('ue').value = u; document.getElementById('iu').value = u; document.getElementById('iu').readOnly = true; document.getElementById('ip').value = p; document.getElementById('it').value = t; document.getElementById('iq').value = q; }
    </script>
</body>
</html>