    sp = cursor.fetchall()
    return render_template('pos.html', san_pham=sp, ten_nv=session['ten_nv'], quyen=session['quyen'])

@app.route('/api/thanh-toan', methods=['POST'])
def thanh_toan():
    data = request.json['cart']
    conn = get_db()
    # Tắt autocommit để bắt đầu Transaction (bảo vệ toàn vẹn dữ liệu)
    conn.autocommit = False 
    cursor = conn.cursor()
    
    try:
        ma_hd = f"HD{datetime.now().strftime('%y%m%d%H%M%S')}"
        tong = sum(item['price'] * item['quantity'] for item in data)
        
        # 1. Tạo hóa đơn
        cursor.execute('INSERT INTO Invoices (InvoiceID, Seller, CreatedDate, TotalAmount) VALUES (?,?,?,?)', 
                       (ma_hd, session['ten_nv'], datetime.now().strftime("%Y-%m-%d"), tong))
        
        # 2. Trừ tồn kho và thêm chi tiết hóa đơn
        for item in data:
            cursor.execute('UPDATE Products SET Stock = Stock - ? WHERE ProductName = ?', (item['quantity'], item['name']))
            cursor.execute('INSERT INTO InvoiceDetails (InvoiceID, ProductName, Quantity, UnitPrice) VALUES (?,?,?,?)', 
                           (ma_hd, item['name'], item['quantity'], item['price']))
        
        # Lưu tất cả thay đổi vào DB nếu không có lỗi
        conn.commit() 
        return jsonify({"status": "success"})
        
    except Exception as e:
        # Nếu có bất kỳ lỗi gì (VD: sập DB giữa chừng), hoàn tác tất cả các thay đổi
        conn.rollback() 
        return jsonify({"status": "error", "message": "Lỗi hệ thống khi thanh toán"}), 500

@app.route('/kho-hang', methods=['GET', 'POST'])
def kho_hang():
    conn = get_db()
    cursor = conn.cursor()
    if request.method == 'POST' and session.get('quyen') == 'Admin':
        ma = request.form.get('ma_sp')
        ten = request.form.get('ten_sp')
        gia = request.form.get('gia_ban')
        ton = request.form.get('so_luong')
        if ma:
            cursor.execute('UPDATE Products SET ProductName=?, Price=?, Stock=? WHERE ID=?', (ten, gia, ton, ma))
        else:
            cursor.execute('INSERT INTO Products (ProductName, Price, Stock) VALUES (?,?,?)', (ten, gia, ton))
        return redirect(url_for('kho_hang'))
        
    cursor.execute('SELECT ID, ProductName, Price, Stock FROM Products')
    sp = cursor.fetchall()
    return render_template('kho_hang.html', san_pham=sp, ten_nv=session['ten_nv'], quyen=session['quyen'])

@app.route('/nhan-vien', methods=['GET', 'POST'])
def nhan_vien():
    conn = get_db()
    cursor = conn.cursor()
    if request.method == 'POST' and session.get('quyen') == 'Admin':
        u = request.form.get('u')
        p = request.form.get('p')
        t = request.form.get('t')
        q = request.form.get('q')
        edit_u = request.form.get('user_edit')
        
        if edit_u:
            cursor.execute('UPDATE Users SET Password=?, FullName=?, Role=? WHERE Username=?', (p, t, q, edit_u))
        else:
            cursor.execute('INSERT INTO Users VALUES (?,?,?,?)', (u, p, t, q))
        return redirect(url_for('nhan_vien'))
        
    cursor.execute('SELECT Username, Password, FullName, Role FROM Users')
    list_nv = cursor.fetchall()
    return render_template('nhan_vien.html', nhan_vien=list_nv, ten_nv=session['ten_nv'], quyen=session['quyen'])

@app.route('/xoa-nv/<user>')
def xoa_nv(user):
    if session.get('quyen') == 'Admin' and user != 'admin':
        get_db().cursor().execute('DELETE FROM Users WHERE Username=?', (user,))
    return redirect(url_for('nhan_vien'))

