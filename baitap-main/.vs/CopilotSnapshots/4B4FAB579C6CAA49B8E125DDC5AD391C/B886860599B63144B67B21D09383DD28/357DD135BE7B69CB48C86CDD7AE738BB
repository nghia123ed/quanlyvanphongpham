@app.route('/api/chi-tiet/<ma_hd>')
def chi_tiet(ma_hd):
    conn = get_db()
    cursor = conn.cursor()
    cursor.execute('SELECT ProductName, Quantity, UnitPrice FROM InvoiceDetails WHERE InvoiceID=?', (ma_hd,))
    rows = cursor.fetchall()
    return jsonify([{"name": r[0], "qty": r[1], "price": r[2]} for r in rows])

