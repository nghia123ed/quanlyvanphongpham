<!DOCTYPE html>
<html>
<head>
    <title>Bán hàng</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="sidebar">
        <h2>{{ ten_nv }}</h2><p>{{ quyen }}</p><hr>
        <a href="/pos" class="active">Bán hàng</a>
        <a href="/kho-hang">Kho hàng</a>
        <a href="/nhan-vien">Nhân viên</a>
        <a href="/lich-su">Lịch sử</a>
        <a href="/thong-ke">Thống kê</a>
        <a href="/logout" style="color:#ff4d4d">Đăng xuất</a>
    </div>
    <div class="content" style="display:flex; gap:20px">
        <div style="flex:2">
            <h2>DANH SÁCH SẢN PHẨM</h2>
            <table>
                <tr><th>Tên SP</th><th>Giá</th><th>Kho</th><th>SL</th><th>Thao tác</th></tr>
                {% for s in san_pham %}
                <tr>
                    <td>{{s[1]}}</td>
                    <td>{{s[2]}}đ</td>
                    <td>{{s[3]}}</td>
                    <td><input type="number" id="q-{{s[0]}}" value="1" min="1" style="width:50px"></td>
                    <td><button onclick="add('{{s[1]}}',{{s[2]}},{{s[0]}})" style="background:#28a745; color:white">Thêm</button></td>
                </tr>
                {% endfor %}
            </table>
        </div>
        <div style="flex:1; background:white; padding:20px; border-radius:10px; box-shadow:0 0 10px #ccc">
            <h3>GIỎ HÀNG</h3><div id="cart" style="min-height:200px"></div><hr>
            <h3 id="total" style="color:red; text-align:right">Tổng: 0đ</h3>
            <button onclick="pay()" style="width:100%; padding:15px; background:#28a745; color:white; font-weight:bold; border:none; cursor:pointer">THANH TOÁN</button>
        </div>
    </div>
    <script>
        let cart = [];
        function add(n, p, id) {
            let q = parseInt(document.getElementById('q-' + id).value);
            let item = cart.find(x => x.name === n);
            if (item) item.quantity += q; else cart.push({ name: n, price: p, quantity: q });
            render();
        }
        function render() {
            let h = '', t = 0;
            cart.forEach((i, idx) => { h += `<p>${i.name} x${i.quantity} = ${i.price * i.quantity}đ <button onclick="cart.splice(${idx},1);render()">X</button></p>`; t += i.price * i.quantity; });
            document.getElementById('cart').innerHTML = h; document.getElementById('total').innerText = 'Tổng: ' + t + 'đ';
        }
        function pay() {
            if (cart.length == 0) return alert('Giỏ hàng trống');
            fetch('/api/thanh-toan', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ cart: cart }) })
                .then(() => { alert('Thanh toán thành công!'); location.reload(); });
        }
    </script>
</body>
</html>