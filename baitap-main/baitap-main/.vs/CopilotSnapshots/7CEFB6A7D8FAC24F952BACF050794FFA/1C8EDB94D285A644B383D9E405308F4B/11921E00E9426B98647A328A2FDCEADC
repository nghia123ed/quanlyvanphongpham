{% extends 'base.html' %}

{% block title %}Thống kê doanh thu{% endblock %}

{% block extra_css %}
<style>
  .main-content{padding:20px}
  #myChart{background:white; padding:20px; border-radius:10px; box-shadow:0 0 10px #ccc}
</style>
{% endblock %}

{% block content %}
<div class="container main-content">
    <h2 class="mb-3">Báo cáo doanh thu</h2>
    <div class="tk-controls">
        <label>From <input type="date" id="startDate"></label>
        <label>To <input type="date" id="endDate"></label>
        <button id="loadBtn" class="btn btn-sm btn-primary">Tải</button>
        <button id="exportCsv" class="btn btn-sm btn-outline-secondary">Xuất CSV</button>
        <div style="margin-left:auto;font-size:13px;color:#6b7280">Tổng: <span id="tkTotal">0</span> đ</div>
    </div>
    <canvas id="myChart"></canvas>
    <div style="margin-top:18px;background:#fff;padding:12px;border-radius:8px">
        <table class="table" id="tkTable"><thead><tr><th>Ngày</th><th>Doanh thu</th></tr></thead><tbody></tbody></table>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
    let chart;
    function formatCurrency(n){ return n.toLocaleString('vi-VN') + ' đ'; }
    function renderChart(labels, values){
        var ctx = document.getElementById('myChart');
        if(chart) chart.destroy();
        chart = new Chart(ctx, { type:'bar', data:{ labels: labels, datasets:[{ label:'Doanh thu (VNĐ)', data: values, backgroundColor:'#28a745' }] }, options:{ responsive:true } });
    }
    function loadData(){
        var s = document.getElementById('startDate').value; var e = document.getElementById('endDate').value;
        var url = '/api/thong-ke' + (s && e? ('?start='+s+'&end='+e) : '');
        fetch(url).then(r=>r.json()).then(function(data){
            renderChart(data.labels, data.values);
            var tbody = document.querySelector('#tkTable tbody'); tbody.innerHTML=''; var total=0;
            data.rows.forEach(function(r){ total += r.total; tbody.innerHTML += '<tr><td>'+ r.date +'</td><td>'+ formatCurrency(r.total) +'</td></tr>'; });
            document.getElementById('tkTotal').innerText = formatCurrency(total);
        }).catch(function(){ alert('Lỗi tải dữ liệu thống kê'); });
    }
    document.getElementById('loadBtn').addEventListener('click', loadData);
    document.getElementById('exportCsv').addEventListener('click', function(){
        var rows = [['Date','Total']]; document.querySelectorAll('#tkTable tbody tr').forEach(function(tr){ rows.push([tr.children[0].innerText, tr.children[1].innerText.replace(/\.| đ/g,'')]); });
        var csv = rows.map(r=>r.join(',')).join('\n'); var blob = new Blob([csv], {type:'text/csv'}); var a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='thong_ke.csv'; a.click();
    });
    // initial load: last 7 days
    (function(){ var d=new Date(); var e=d.toISOString().slice(0,10); d.setDate(d.getDate()-6); var s=d.toISOString().slice(0,10); document.getElementById('startDate').value=s; document.getElementById('endDate').value=e; loadData(); })();
    </script>
</div>
{% endblock %}
