{% extends 'base.html' %}

{% block title %}Lịch sử hóa đơn{% endblock %}

{% block extra_css %}
<style>
  .main-content{padding:20px}
  table{width:100%;border-collapse:collapse}
  th,td{padding:12px;border-bottom:1px solid #eef2f7}
  .btn-detail{background:#17a2b8;color:white;border:none;padding:6px 10px;border-radius:6px}
  /* modal style for invoice details */
  .detail-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:1990}
  .detail-modal{display:none;position:fixed;left:50%;top:80px;transform:translateX(-50%);width:90%;max-width:1000px;max-height:calc(100vh - 120px);overflow:auto;background:white;padding:18px;border-radius:10px;box-shadow:0 8px 24px rgba(2,6,23,0.4);z-index:2000}
  .detail-modal .close-btn{position:absolute;right:12px;top:8px;background:none;border:none;font-size:18px;cursor:pointer}
</style>
{% endblock %}

{% block content %}
<div class="container main-content">
    <h2 class="mb-3">Lịch sử hóa đơn</h2>
    <table class="table table-hover">
        <thead class="table-dark"><tr><th>Mã HD</th><th>Người bán</th><th>Khách hàng</th><th>Ngày</th><th>Tổng tiền</th><th>Thao tác</th></tr></thead>
        <tbody>
            {% for h in hoa_don %}
            {# h may be (InvoiceID, Seller, CreatedDate, TotalAmount) or include Customer as 5th element #}
            <tr data-id="{{h[0]}}" data-created="{{h[2]}}" data-customer="{{ h[4] if h|length > 4 else '' }}">
                <td>{{h[0]}}</td>
                <td>{{h[1]}}</td>
                <td>{{ h[4] if h|length > 4 else '' }}</td>
                <td>{{h[2]}}</td>
                <td>{{h[3]}}đ</td>
                <td><button type="button" class="btn-detail" onclick="showDetail(this)">Xem chi tiết</button></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <!-- overlay + modal for invoice detail -->
    <div id="detailOverlay" class="detail-overlay"></div>
    <div id="detailModal" class="detail-modal" role="dialog" aria-modal="true">
        <button class="close-btn" onclick="closeDetail()">✕</button>
        <h3 id="detail-title"></h3>
        <div class="table-responsive">
          <table id="detail-table" class="table">
              <thead><tr class="table-secondary"><th>Tên SP</th><th>Số lượng</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
              <tbody id="detail-body"></tbody>
          </table>
        </div>
        <h3 id="detail-total" style="text-align:right; color:red"></h3>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
    function showDetail(btn) {
        var tr = btn.closest('tr');
        var ma = tr.dataset.id;
        var created = tr.dataset.created || '';
        fetch('/api/chi-tiet/' + ma).then(res => res.json()).then(data => {
            document.getElementById('detail-box').style.display = 'block';
            var customer = tr.dataset.customer || '';
            document.getElementById('detail-title').innerText = 'Chi tiết hóa đơn: ' + ma + (customer? (' — Khách: ' + customer) : (created? (' — ' + created) : ''));
            let h = '', total = 0;
            data.forEach(item => {
                h += `<tr><td>${item.name}</td><td>${item.qty}</td><td>${item.price}đ</td><td>${item.qty * item.price}đ</td></tr>`;
                total += item.qty * item.price;
            });
            document.getElementById('detail-body').innerHTML = h;
            document.getElementById('detail-total').innerText = 'Tổng cộng: ' + total + 'đ';
            window.scrollTo(0, document.body.scrollHeight);
        });
    }

    (function(){
        try{
            var params = new URLSearchParams(window.location.search);
            var inv = params.get('invoice');
            if(inv){
                var row = document.querySelector('tr[data-id="'+inv+'"]');
                if(row){ row.style.background = '#fff3cd'; row.scrollIntoView({behavior:'smooth', block:'center'}); var btn = row.querySelector('button'); if(btn) setTimeout(function(){ btn.click(); }, 300); }
            }
        }catch(e){ }
    })();
</script>
{% endblock %}
