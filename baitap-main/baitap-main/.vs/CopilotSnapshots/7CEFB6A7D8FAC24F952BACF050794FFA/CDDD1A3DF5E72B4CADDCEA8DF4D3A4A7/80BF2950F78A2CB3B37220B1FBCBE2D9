<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Pos System{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/static/style.css">
    <style>
      /* Global topbar (moved from left sidebar to top) */
      /* compact topbar: approx 1cm height */
      .topbar{width:100%; background:#1f2937; color:#fff; height:1cm; min-height:1cm; line-height:1cm; display:flex; gap:8px; align-items:center; padding:0 12px; overflow:hidden; position:fixed; top:0; left:0; right:0; z-index:1030}
      .topbar .brand{font-weight:600; margin-right:8px; font-size:0.95rem}
      .topbar a{color:#cbd5e1;padding:6px 8px;text-decoration:none;border-radius:6px;margin-right:6px;font-size:0.9rem;display:inline-block}
      .topbar a.active, .topbar a:hover{background:#3b82f6;color:#fff}
      /* Reset left-margin since topbar replaces fixed sidebar */
      main.col-md-10, main{margin-left:0}
      @media(max-width:768px){ .topbar{height:auto; min-height:auto; padding:6px 8px; flex-wrap:wrap} }
      /* prevent page content being hidden under fixed topbar */
      main, .main-content{padding-top:calc(1cm + 1rem)}

      /* make nav horizontally scrollable instead of wrapping */
      .topbar nav{overflow-x:auto; white-space:nowrap}
    </style>
    {% block extra_css %}{% endblock %}
</head>
<body>
<!-- top navigation bar -->
<div class="topbar">
  <div class="brand">Office Supplies POS</div>
  <nav style="display:flex;gap:8px;flex:1">
    <a class="{% if request.path == '/pos' %}active{% endif %}" href="/pos">Bán hàng</a>
    <a class="{% if request.path == '/kho-hang' %}active{% endif %}" href="/kho-hang">Kho hàng</a>
    <a class="{% if request.path == '/nhan-vien' %}active{% endif %}" href="/nhan-vien">Nhân viên</a>
    <a class="{% if request.path == '/lich-su' %}active{% endif %}" href="/lich-su">Lịch sử</a>
    <a class="{% if request.path == '/thong-ke' %}active{% endif %}" href="/thong-ke">Thống kê</a>
  </nav>
  <div style="margin-left:auto;color:#e6eefb">
    <span style="margin-right:12px">{{ ten_nv }}{% if quyen %} - {{ quyen }}{% endif %}</span>
    <a href="/logout" style="color:#ffccd5">Đăng xuất</a>
  </div>
</div>
<div class="container-fluid">
  <div class="row">
    <main class="col-12 px-4 py-4">
      {% block content %}{% endblock %}
    </main>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% block extra_js %}{% endblock %}
<!-- JS error banner (shows runtime JS errors on page to help debugging) -->
<div id="jsErrorBanner" style="display:none;position:fixed;left:12px;right:12px;bottom:12px;background:#fff3f3;border:1px solid #ffb3b3;color:#611;padding:10px;border-radius:6px;z-index:9999;font-size:13px;box-shadow:0 4px 20px rgba(0,0,0,0.2)"></div>
<script>
  window.addEventListener('error', function(e){
    try{
      var b = document.getElementById('jsErrorBanner');
      b.innerText = 'JS error: ' + (e && e.message ? e.message : String(e));
      b.style.display = 'block';
      console.error('Captured JS error', e);
    }catch(_){ }
  });
  window.addEventListener('unhandledrejection', function(ev){
    try{
      var b = document.getElementById('jsErrorBanner');
      b.innerText = 'Promise rejection: ' + (ev && ev.reason ? (ev.reason.message || ev.reason) : String(ev));
      b.style.display = 'block';
      console.error('Unhandled rejection', ev);
    }catch(_){ }
  });
</script>
</body>
</html>