<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Pos System{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/static/style.css">
    <style>
      /* Global topbar (moved from left sidebar to top) */
      .topbar{width:100%; background:#1f2937; color:#fff; padding:10px 18px; display:flex; gap:8px; align-items:center; flex-wrap:wrap}
      .topbar .brand{font-weight:600; margin-right:12px}
      .topbar a{color:#cbd5e1;padding:8px 10px;text-decoration:none;border-radius:6px;margin-right:6px}
      .topbar a.active, .topbar a:hover{background:#3b82f6;color:#fff}
      /* Reset left-margin since topbar replaces fixed sidebar */
      main.col-md-10, main{margin-left:0}
      @media(max-width:768px){ .topbar{padding:8px 12px} }
    </style>
    {% block extra_css %}{% endblock %}
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="#">Office Supplies POS</a>
    <div class="collapse navbar-collapse">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><span class="navbar-text text-light">{{ ten_nv }} {% if quyen %} - {{ quyen }}{% endif %}</span></li>
        <li class="nav-item"><a class="nav-link text-danger" href="/logout">Đăng xuất</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- top navigation bar to replace left sidebar -->
<div class="topbar">
  <div class="brand">Office Supplies POS</div>
  <a class="{% if request.path == '/pos' %}active{% endif %}" href="/pos">Bán hàng</a>
  <a class="{% if request.path == '/kho-hang' %}active{% endif %}" href="/kho-hang">Kho hàng</a>
  <a class="{% if request.path == '/nhan-vien' %}active{% endif %}" href="/nhan-vien">Nhân viên</a>
  <a class="{% if request.path == '/lich-su' %}active{% endif %}" href="/lich-su">Lịch sử</a>
  <a class="{% if request.path == '/thong-ke' %}active{% endif %}" href="/thong-ke">Thống kê</a>
</div>
<div class="container-fluid">
  <div class="row">
    <aside class="col-md-2 d-none d-md-block bg-light sidebar py-3">
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link {% if request.path == '/pos' %}active{% endif %}" href="/pos">Bán hàng</a></li>
        <li class="nav-item"><a class="nav-link {% if request.path == '/kho-hang' %}active{% endif %}" href="/kho-hang">Kho hàng</a></li>
        <li class="nav-item"><a class="nav-link {% if request.path == '/nhan-vien' %}active{% endif %}" href="/nhan-vien">Nhân viên</a></li>
        <li class="nav-item"><a class="nav-link {% if request.path == '/lich-su' %}active{% endif %}" href="/lich-su">Lịch sử</a></li>
        <li class="nav-item"><a class="nav-link {% if request.path == '/thong-ke' %}active{% endif %}" href="/thong-ke">Thống kê</a></li>
      </ul>
    </aside>
    <main class="col-md-10 ms-sm-auto px-4 py-4">
      {% block content %}{% endblock %}
    </main>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% block extra_js %}{% endblock %}
</body>
</html>